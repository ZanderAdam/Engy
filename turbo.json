{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "dev": {
      "persistent": true,
      "cache": false,
      "passThroughEnv": ["ENGY_DIR", "PORT", "ENGY_SERVER_URL"]
    },
    "start": {
      "persistent": true,
      "cache": false,
      "passThroughEnv": ["ENGY_DIR", "PORT", "ENGY_SERVER_URL"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**", "dist-server/**"]
    },
    "lint:eslint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
